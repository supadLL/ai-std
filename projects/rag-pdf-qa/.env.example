LLM_PROVIDER=deepseek
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Backward-compatible DeepSeek variables. Prefer LLM_* for new setups.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
REQUEST_TIMEOUT_SECONDS=30
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
QDRANT_MODE=local
QDRANT_LOCAL_PATH=.qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=rag
QDRANT_COLLECTION=rag_chunks
DOCUMENT_METADATA_PATH=data/documents.json
USER_STORE_PATH=data/users.json
INDEX_JOB_STORAGE_PATH=data/index_jobs
DATABASE_URL=sqlite:///data/app.db
APP_SECRET_KEY=change-this-local-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Optional OCR setting for Windows if tesseract.exe is not in PATH.
# Example: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
